# Optional local overrides. Copy to .env only for local shell tooling; .env is ignored.

# Wrapper profile root override. Usually not needed because ./bootstrap.sh stores
# this repo's my-pi-agents path with `pi agent-path`.
# PI_AGENTS_HOME=/absolute/path/to/my-pi/my-pi-agents

# Real Pi binary if auto-detection cannot find it.
# PI_REAL_BIN=/opt/homebrew/bin/pi

# Machine-local default Pi profile that contains auth.json/models.json.
# PI_DEFAULT_AGENT_DIR=$HOME/.pi/agent

# Wrapper config location for the stored agent-path value.
# PI_WRAPPER_CONFIG_DIR=$HOME/.config/custom-pi-agents

# Firecrawl MCP auth for profiles using the firecrawl pack.
# Get a key at: https://www.firecrawl.dev/app/api-keys
# FIRECRAWL_API_KEY=fc-YOUR_API_KEY
