{
  "name": "pi-workflows",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reusable deterministic workflow kit for Pi SDK profile agents.",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "bin": {
    "pi-workflow": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "workflow": "tsx src/cli.ts",
    "example:fix-tests": "tsx src/cli.ts examples/fix-tests.workflow.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
